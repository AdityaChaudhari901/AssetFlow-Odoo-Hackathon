ASSETFLOW_APP_NAME=AssetFlow API
ASSETFLOW_APP_VERSION=0.1.0
ASSETFLOW_ENVIRONMENT=development
ASSETFLOW_DEBUG=true
ASSETFLOW_API_V1_PREFIX=/api/v1
ASSETFLOW_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Supabase project configuration. Keep real values in Backend/.env only.
ASSETFLOW_SUPABASE_URL=https://your-project-ref.supabase.co
ASSETFLOW_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key
# Service-role / secret key — server only, never ships to a client.
ASSETFLOW_SUPABASE_SECRET_KEY=replace-with-secret-key
# Legacy HS256 JWT secret (Dashboard -> Settings -> API). Leave unset on projects
# using the new asymmetric signing keys; JWKS verification kicks in instead.
ASSETFLOW_SUPABASE_JWT_SECRET=

# Where password-reset emails send users back to.
ASSETFLOW_FRONTEND_URL=http://localhost:5173
ASSETFLOW_STORAGE_BUCKET=assetflow-files

# Shared secret for /api/v1/jobs/scan. Vercel Cron sends it automatically when a
# CRON_SECRET project env var exists; mirror the same value here.
ASSETFLOW_CRON_SECRET=replace-with-random-32-chars
